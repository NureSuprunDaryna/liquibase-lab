<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-insert-skills-seed-data-v003" author="alyona">
        <preConditions onFail="HALT">
            <tableExists tableName="skills"/>
            <tableExists tableName="users"/>
        </preConditions>

        <insert tableName="skills">
            <column name="name" value="Project Management"/>
            <column name="description" value="Managing teams and workflows"/>
            <column name="user_id" value="11111111-1111-1111-1111-111111111111"/>
        </insert>

        <insert tableName="skills">
            <column name="name" value="Java"/>
            <column name="description" value="Backend development"/>
            <column name="user_id" value="22222222-2222-2222-2222-222222222222"/>
        </insert>

        <insert tableName="skills">
            <column name="name" value="SQL"/>
            <column name="description" value="Database querying"/>
            <column name="user_id" value="22222222-2222-2222-2222-222222222222"/>
        </insert>

        <insert tableName="skills">
            <column name="name" value="Frontend"/>
            <column name="description" value="UI development"/>
            <column name="user_id" value="33333333-3333-3333-3333-333333333333"/>
        </insert>

        <insert tableName="skills">
            <column name="name" value="Docker"/>
            <column name="description" value="Containerization"/>
            <column name="user_id" value="44444444-4444-4444-4444-444444444444"/>
        </insert>

        <rollback>
            <delete tableName="skills">
                <where>name IN ('Project Management', 'Java', 'SQL', 'Frontend', 'Docker')</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>