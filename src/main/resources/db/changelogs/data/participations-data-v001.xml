        </preConditions>

        <insert tableName="participations">
            <column name="user_id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="context_role_id" valueNumeric="1"/>
            <column name="joined_at" valueDate="2026-03-01T09:00:00"/>
