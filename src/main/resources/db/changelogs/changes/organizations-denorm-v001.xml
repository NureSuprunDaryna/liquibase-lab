<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-add-organizations-denormalized-counters-v001" author="daryna">
        <preConditions onFail="HALT">
            <tableExists tableName="organizations"/>
            <not>
                <columnExists tableName="organizations" columnName="active_projects_count"/>
            </not>
            <not>
                <columnExists tableName="organizations" columnName="active_events_count"/>
            </not>
        </preConditions>

        <addColumn tableName="organizations">
            <column name="active_projects_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="active_events_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="organizations" columnName="active_projects_count"/>
            <dropColumn tableName="organizations" columnName="active_events_count"/>
        </rollback>
    </changeSet>

</databaseChangeLog>